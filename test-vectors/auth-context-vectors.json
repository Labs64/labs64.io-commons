{
  "description": "Canonical behavior vectors for the auth-context libraries (Java + Python). Both implementations MUST pass every case. Contract: trusted header contract in labs64.io-authproxy.",
  "headers": {
    "user": "X-Auth-User",
    "scopes": "X-Auth-Scopes",
    "tenant": "X-Auth-Tenant",
    "requestId": "X-Request-ID"
  },
  "valuePattern": "^[a-zA-Z0-9_.:-]+$",
  "tenantNone": "-",
  "cases": [
    {
      "name": "full-context-accepted",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read,ecommerce:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000001"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": ["account:read", "ecommerce:read"],
        "requestId": "0198a7b0-1111-7abc-8def-000000000001"
      }
    },
    {
      "name": "tenantless-dash-maps-to-null",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "ecommerce:read",
        "X-Auth-Tenant": "-",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000002"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": null,
        "scopes": ["ecommerce:read"],
        "requestId": "0198a7b0-1111-7abc-8def-000000000002"
      }
    },
    {
      "name": "empty-scopes-header-means-no-scopes",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000003"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": [],
        "requestId": "0198a7b0-1111-7abc-8def-000000000003"
      }
    },
    {
      "name": "missing-scopes-header-means-no-scopes",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000004"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": [],
        "requestId": "0198a7b0-1111-7abc-8def-000000000004"
      }
    },
    {
      "name": "missing-user-on-protected-path-rejected",
      "public": false,
      "headers": {
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000005"
      },
      "expect": { "outcome": "reject" }
    },
    {
      "name": "empty-user-on-protected-path-rejected",
      "public": false,
      "headers": {
        "X-Auth-User": "",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000006"
      },
      "expect": { "outcome": "reject" }
    },
    {
      "name": "missing-user-on-public-path-anonymous",
      "public": true,
      "headers": {},
      "expect": { "outcome": "anonymous" }
    },
    {
      "name": "valid-context-on-public-path-still-populated",
      "public": true,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000007"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": ["account:read"],
        "requestId": "0198a7b0-1111-7abc-8def-000000000007"
      }
    },
    {
      "name": "invalid-chars-in-user-rejected",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe evil",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000008"
      },
      "expect": { "outcome": "reject" }
    },
    {
      "name": "invalid-chars-in-tenant-rejected",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t 100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-000000000009"
      },
      "expect": { "outcome": "reject" }
    },
    {
      "name": "invalid-scope-item-rejected",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read,bad scope",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-00000000000a"
      },
      "expect": { "outcome": "reject" }
    },
    {
      "name": "scopes-csv-items-are-trimmed",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read, ecommerce:read ,",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-00000000000b"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": ["account:read", "ecommerce:read"],
        "requestId": "0198a7b0-1111-7abc-8def-00000000000b"
      }
    },
    {
      "name": "service-principal-colon-allowed",
      "public": false,
      "headers": {
        "X-Auth-User": "svc:checkout-be",
        "X-Auth-Scopes": "ecommerce:read",
        "X-Auth-Tenant": "-",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-00000000000c"
      },
      "expect": {
        "outcome": "accept",
        "user": "svc:checkout-be",
        "tenant": null,
        "scopes": ["ecommerce:read"],
        "requestId": "0198a7b0-1111-7abc-8def-00000000000c",
        "servicePrincipal": true
      }
    },
    {
      "name": "missing-request-id-is-generated-locally",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": ["account:read"],
        "requestId": "GENERATED"
      }
    },
    {
      "name": "invalid-request-id-is-replaced-not-rejected",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "abc def"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": "t_100",
        "scopes": ["account:read"],
        "requestId": "GENERATED"
      }
    },
    {
      "name": "missing-tenant-header-maps-to-null",
      "public": false,
      "headers": {
        "X-Auth-User": "jdoe",
        "X-Auth-Scopes": "account:read",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-00000000000d"
      },
      "expect": {
        "outcome": "accept",
        "user": "jdoe",
        "tenant": null,
        "scopes": ["account:read"],
        "requestId": "0198a7b0-1111-7abc-8def-00000000000d"
      }
    },
    {
      "name": "invalid-user-on-public-path-anonymous-not-rejected",
      "public": true,
      "headers": {
        "X-Auth-User": "jdoe evil",
        "X-Auth-Scopes": "account:read",
        "X-Auth-Tenant": "t_100",
        "X-Request-ID": "0198a7b0-1111-7abc-8def-00000000000e"
      },
      "expect": { "outcome": "anonymous" }
    }
  ]
}
